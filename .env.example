# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dealfinder

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Affiliate
AFFILIATE_BASE_URL=https://affiliate.example.com/redirect?url=

# Cache
CACHE_TTL_SECONDS=600

# JWT Auth
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
